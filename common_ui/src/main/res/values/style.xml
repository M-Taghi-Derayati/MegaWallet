<resources>
    <style name="KrakenButton">
        <item name="android:minHeight">@dimen/_35sdp</item>
        <item name="android:height">@dimen/_42sdp</item>
        <item name="android:paddingLeft">@dimen/_20sdp</item>
        <item name="android:paddingRight">@dimen/_20sdp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:textAppearance">@style/Regular2</item>
        <item name="android:elevation">@dimen/_5sdp</item> <!-- سایه لطیف -->
    </style>




    <!--region TextView Styles-->

    <style name="TextViewLight1" parent="Widget.AppCompat.TextView">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAppearance">@style/Light1</item>
    </style>

    <style name="TextViewLight2" parent="Widget.AppCompat.TextView">
